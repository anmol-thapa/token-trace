{
  "manifest_version": 3,
  "name": "TokenTrace",
  "version": "1.0.0",
  "description": "Real-time token usage and CO\u2082 tracking for Claude and ChatGPT. Syncs with the TokenTrace desktop app.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TokenTrace"
  },
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "http://localhost:3002/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
